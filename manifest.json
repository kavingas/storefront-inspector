{
    "manifest_version": 3,
    "name": "Commerce Events Debugger",
    "version": "1.0.7",
    "description": "Verifies Adobe Commerce storefront events and Product Recommendation events including data integrity",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Commerce Events Debugger",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "background": {
        "service_worker": "background.js"
    },
    "devtools_page": "devtools.html",
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["injected.js"],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "run_at": "document_start"
        }
    ],
    "permissions": ["storage", "tabs"],
    "host_permissions": ["https://api.github.com/*"]
}
